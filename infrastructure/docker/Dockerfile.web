FROM node:22.15.0-alpine AS build
WORKDIR /app
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
COPY package.json package-lock.json* turbo.json tsconfig.base.json ./
COPY apps/web/package.json apps/web/package.json
COPY packages ./packages
RUN npm install
COPY apps/web ./apps/web
RUN npm run build --workspace=@arrowera/web

FROM node:22.15.0-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup -S arrowera && adduser -S arrowera -G arrowera
COPY --from=build --chown=arrowera:arrowera /app ./
USER arrowera
EXPOSE 3000
CMD ["npm", "run", "start", "--workspace=@arrowera/web"]
