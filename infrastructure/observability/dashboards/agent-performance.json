{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [{ "expr": "rate(agent_execution_duration_seconds_sum[5m]) / rate(agent_execution_duration_seconds_count[5m])", "legendFormat": "{{agent_name}}" }],
      "title": "Avg Agent Execution Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [{ "expr": "sum(rate(agent_runs_total[1h])) by (status)", "legendFormat": "{{status}}" }],
      "title": "Agent Runs by Status",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [{ "expr": "sum(agent_runs_total) by (provider)", "legendFormat": "{{provider}}" }],
      "title": "Runs by LLM Provider",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "USD" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [{ "expr": "sum(llm_cost_usd_total) by (provider)", "legendFormat": "{{provider}}" }],
      "title": "LLM API Costs",
      "type": "stat"
    }
  ],
  "schemaVersion": 39,
  "tags": ["arrowera", "agents"],
  "title": "ArrowEra Agent Performance",
  "uid": "arrowera-agent-perf"
